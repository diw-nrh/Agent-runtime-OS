# === AgentRuntime-OS Environment Variables ===
# Copy this file to .env and fill in your values
# For Docker Compose, the .env file in the root directory will be automatically loaded

# --- Backend Configuration ---
# API Key for OpenRouter (Optional, used for specific models)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Redis URL for Celery and caching (Default works for docker-compose)
REDIS_URL="redis://redis:6379/0"

# Secret used to authenticate internal requests between frontend and backend
INTERNAL_API_SECRET="nodebook-secret-dev"

# --- Frontend Configuration ---
# URL for the backend API
BACKEND_URL="http://backend:8000"
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"

# NextAuth Configuration
# Generate a secure random string for production
NEXTAUTH_SECRET="supersecretjwtkey12345"

# --- Security Configuration ---
# 32-byte hex string for AES-256-GCM encryption at rest
ENCRYPTION_SECRET="generate_32_byte_hex_string_here"

# --- Database Configuration ---
# PostgreSQL connection string
DATABASE_URL="postgresql://admin:password@postgres:5432/agent_db?schema=public"
NEXTAUTH_URL=

# --- Langfuse Configuration ---
LANGFUSE_SECRET_KEY=" sk-lf-...\nLANGFUSE_PUBLIC_KEY=\pk-lf-...\nLANGFUSE_HOST=\https://cloud.langfuse.com\n
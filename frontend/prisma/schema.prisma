generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("USER")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces Workspace[]
  mcpTools   McpTool[]
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blueprints AgentBlueprint[]
}

model AgentBlueprint {
  id          String   @id @default(uuid())
  name        String
  description String?
  
  canvasData  Json     
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model McpTool {
  id          String   @id @default(uuid())
  name        String
  description String?
  isPublic    Boolean  @default(false)
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  versions    McpToolVersion[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model McpToolVersion {
  id          String   @id @default(uuid())
  version     String   // e.g., "1.0.0"
  config      Json     // Details like {"command": "npx", "args": ["@modelcontextprotocol/server-postgres"]}
  changelog   String?
  
  toolId      String
  tool        McpTool  @relation(fields: [toolId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String            @id @default(uuid())
  email       String            @unique
  password    String
  name        String?
  role        String            @default("USER")
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  workspaces  Workspace[]
  mcpTools    McpTool[]
  memberships WorkspaceMember[]
}

model Workspace {
  id          String            @id @default(uuid())
  name        String
  ownerId     String
  owner       User              @relation(fields: [ownerId], references: [id])
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  blueprints  AgentBlueprint[]
  members     WorkspaceMember[]

  @@index([deletedAt])
}

model AgentBlueprint {
  id          String   @id @default(uuid())
  name        String
  description String?
  
  canvasData  Json     
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  
  runs        AgentExecutionRun[]

  @@index([deletedAt])
}

model McpTool {
  id          String   @id @default(uuid())
  name        String
  description String?
  isPublic    Boolean  @default(false)
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  versions    McpToolVersion[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([deletedAt])
}

model McpToolVersion {
  id          String   @id @default(uuid())
  version     String   // e.g., "1.0.0"
  config      Json     // Details like {"command": "npx", "args": ["@modelcontextprotocol/server-postgres"]}
  changelog   String?
  
  toolId      String
  tool        McpTool  @relation(fields: [toolId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model AgentExecutionRun {
  id          String   @id @default(uuid())
  blueprintId String?
  blueprint   AgentBlueprint? @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  
  status      String   @default("RUNNING") // RUNNING, COMPLETED, ERROR
  startedAt   DateTime @default(now())
  completedAt DateTime?
  
  traces      AgentTraceStep[]
}

model AgentTraceStep {
  id          String   @id @default(uuid())
  runId       String
  run         AgentExecutionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  
  stepIndex   Int
  agentId     String?  // The LangGraph Node/Agent name
  type        String   // "THOUGHT", "TOOL_CALL", "TOOL_RESULT", "MESSAGE", "ERROR"
  content     Json     // Detail payload
  
  createdAt   DateTime @default(now())
}

enum WorkspaceRole {
  ADMIN
  MEMBER
  VIEWER
}

enum WorkspaceMemberStatus {
  PENDING
  ACTIVE
  REJECTED
}

model WorkspaceMember {
  id          String                @id @default(uuid())
  workspaceId String
  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole         @default(MEMBER)
  status      WorkspaceMemberStatus @default(PENDING)
  joinedAt    DateTime              @default(now())

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model checkpoint_blobs {
  thread_id     String
  checkpoint_ns String @default("")
  channel       String
  version       String
  type          String
  blob          Bytes?

  @@id([thread_id, checkpoint_ns, channel, version])
  @@ignore
}

model checkpoint_migrations {
  v Int @id

  @@ignore
}

model checkpoint_writes {
  thread_id     String
  checkpoint_ns String @default("")
  checkpoint_id String
  task_id       String
  idx           Int
  channel       String
  type          String?
  blob          Bytes
  task_path     String @default("")

  @@id([thread_id, checkpoint_ns, checkpoint_id, task_id, idx])
  @@ignore
}

model checkpoints {
  thread_id            String
  checkpoint_ns        String  @default("")
  checkpoint_id        String
  parent_checkpoint_id String?
  type                 String?
  checkpoint           Json
  metadata             Json

  @@id([thread_id, checkpoint_ns, checkpoint_id])
  @@ignore
}

